# 仓颉 FOS 环境变量配置模板
# 复制此文件为 .env，然后填写实际值
# 注意：.env 文件不会被 git 追踪（含密码，严禁上传）

# ── AI 能力 ──────────────────────────────────────────────────────────────────
# DeepSeek API Key（AI 分析、对话、情报提取）
DEEPSEEK_API_KEY=

# 阿里云 DashScope Key（语音转写 ASR）
DASHSCOPE_API_KEY=

# ── 登录账号配置 ──────────────────────────────────────────────────────────────
# 格式：账号:密码:tenant_id，多账号用英文逗号分隔
# tenant_id 决定数据隔离范围，同一 tenant_id 的账号共享数据
# 留空 = 开发模式（任意账号均可登录，tenant_id 为 default）
#
# 单账号示例：
# FOS_ACCOUNTS=zt001:123456:zt
#
# 多账号示例（每个账号数据完全隔离）：
# FOS_ACCOUNTS=zt001:123456:zt,gk001:123456:gk
#
# 当前配置（两位同事独立数据）：
FOS_ACCOUNTS=zt001:123456:zt,gk001:123456:gk

# ── GitHub 数据同步（可选）────────────────────────────────────────────────────
# 用于自动同步路演报告到 GitHub 仓库
COACH_DATA_GITHUB_TOKEN=
COACH_DATA_GITHUB_REPO=
COACH_DATA_TENANT_ID=
